{
  "version": 2,
  "env": {
    "GEMINI_API_KEY": "@GEMINI_API_KEY"
  },
  "builds": [
    {
      "src": ".vscode/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/$",
      "dest": ".vscode/landingpage-01.html"
    },
    {
      "src": "/(.*)",
      "dest": ".vscode/$1"
    }
  ]
}
